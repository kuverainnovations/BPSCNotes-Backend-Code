# ═══════════════════════════════════════════════════
# BPSCNotes Backend — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=api/v1
APP_NAME=BPSCNotes
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────
DB_HOST=bpscnotes-postgres
DB_PORT=5432
DB_NAME=bpscnotes
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_LOGGING=false

# ── Redis ─────────────────────────────────────────
REDIS_HOST=bpscnotes-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300
REDIS_DB=0

# ── JWT ───────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ── Admin JWT ─────────────────────────────────────
ADMIN_JWT_SECRET=CHANGE_THIS_TO_YET_ANOTHER_64_CHAR_RANDOM_STRING
ADMIN_JWT_EXPIRES_IN=24h

# ── OTP (MSG91) ───────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=BPSCNT
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Firebase FCM ──────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com

# ── Throttle / Rate Limiting ──────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_OTP_TTL=900
THROTTLE_OTP_LIMIT=5

# ── File Upload ───────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Business Rules ────────────────────────────────
COIN_VALUE_INR=0.10
MAX_COIN_DISCOUNT_SUB=30
MAX_COIN_DISCOUNT_COURSE=50
REFERRAL_COINS_REFERRER=50
REFERRAL_COINS_REFEREE=30
DAILY_LOGIN_COINS=2
